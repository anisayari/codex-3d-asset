{
  "confirmBeforeTripoGeneration": true,
  "confirmationPrompt": "The reference image is ready. Do you want me to launch the Tripo 3D generation now?",
  "skipConfirmationWhenExplicitlyRequested": true,
  "postConfirmationBehavior": "continue immediately with the Tripo API in the same turn",
  "localViewer": {
    "enabled": true,
    "reportViewerUrlInCodexResponse": true,
    "doNotUsePlaywrightForPreview": true,
    "pluginBootstrapsDependencies": true,
    "pluginStartsLocalViewerServer": true,
    "preferWidgetTool": "show_3d_asset_widget",
    "widgetRequestsFullscreenOnMount": true,
    "defaultPort": 4174,
    "runtimeConfigPath": "../../.codex-runtime/viewer.json",
    "entryPath": "/viewer/index.html",
    "queryParameter": "model",
    "previewOutputPrefix": "/outputs/",
    "supportedPreviewFormats": [
      "glb",
      "gltf",
      "fbx",
      "obj",
      "stl",
      "usdz"
    ],
    "archiveBehavior": "extract first supported preview file from zip when possible"
  }
}

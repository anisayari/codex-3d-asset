{
  "baseUrl": "https://api.tripo3d.ai/v2/openapi",
  "auth": {
    "type": "bearer",
    "envVar": "TRIPO_API_KEY"
  },
  "workflow": [
    {
      "name": "uploadReferenceImage",
      "method": "POST",
      "path": "/upload/sts",
      "contentType": "multipart/form-data",
      "resultField": "data.image_token"
    },
    {
      "name": "createImageToModelTask",
      "method": "POST",
      "path": "/task",
      "contentType": "application/json",
      "body": {
        "type": "image_to_model",
        "file": {
          "type": "jpg",
          "file_token": "<image_token>"
        }
      },
      "resultField": "data.task_id"
    },
    {
      "name": "pollTask",
      "method": "GET",
      "path": "/task/{task_id}"
    },
    {
      "name": "convertModel",
      "method": "POST",
      "path": "/task",
      "contentType": "application/json",
      "body": {
        "type": "convert_model",
        "format": "<FBX|GLTF|OBJ|STL|USDZ>",
        "original_model_task_id": "<generation_task_id>"
      },
      "resultField": "data.task_id"
    }
  ],
  "notes": [
    "Prefer direct API calls over browser automation.",
    "Check the API key before generating the reference when the user asked for Tripo handoff.",
    "Continue automatically after image generation when the key is present.",
    "GLB is the default direct download from generation output.",
    "FBX, GLTF, OBJ, STL, and USDZ use convert_model after generation succeeds.",
    "OBJ conversion can return a zip artifact rather than a bare .obj file."
  ]
}
